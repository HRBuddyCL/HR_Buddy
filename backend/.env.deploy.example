# ------------------------------------------------------------------------------
# HR-Buddy backend deploy environment template (Railway/Vercel + Neon + Pipedream)
# ------------------------------------------------------------------------------
# How to use:
# 1) Copy values to Railway service environment variables (Production).
# 2) Replace every placeholder value before deploy.
# 3) Never commit real secrets, passwords, API keys, or connection strings.
# ------------------------------------------------------------------------------

NODE_ENV=production
RUNTIME_ENV=production
PORT=3001
RUNTIME_CONFIG_STRICT=false
READINESS_STRICT_PROVIDERS=false

# Frontend origins (comma-separated, no trailing slash)
CORS_ORIGINS=https://<vercel-production-domain>,https://<vercel-git-main-domain>
CORS_ALLOW_CREDENTIALS=true

# Database (Neon)
# Runtime: pooled connection
DATABASE_URL=postgresql://<neon_user>:<neon_password>@<neon_pooler_host>/<neon_db>?sslmode=require&uselibpqcompat=true&channel_binding=require
# Migrations: direct connection
DIRECT_DATABASE_URL=postgresql://<neon_user>:<neon_password>@<neon_direct_host>/<neon_db>?sslmode=require&uselibpqcompat=true&channel_binding=require

GEO_DATASET_PATH=
TRUST_PROXY=
HEALTH_CHECK_TOKEN=<generate_random_token>

# OTP Core
OTP_HASH_SECRET=<generate_random_secret_32_plus_chars>
OTP_CODE_TTL_MINUTES=5
OTP_SESSION_TTL_MINUTES=30
OTP_MAX_ATTEMPTS=5
OTP_ATTEMPT_LOCK_MINUTES=5
OTP_SEND_COOLDOWN_SECONDS=60
OTP_MAX_SEND_PER_HOUR=6

# OTP Delivery (Production recommended: webhook)
OTP_DELIVERY_PROVIDER=webhook
OTP_WEBHOOK_URL=https://<pipedream_or_gateway_webhook_url>
OTP_WEBHOOK_API_KEY=<generate_random_api_key>
OTP_WEBHOOK_SIGNING_SECRET=<generate_random_secret_32_plus_chars>
OTP_WEBHOOK_INCLUDE_PHONE=false
OTP_WEBHOOK_TIMEOUT_MS=5000
OTP_WEBHOOK_MAX_RETRIES=2
OTP_WEBHOOK_RETRY_DELAY_MS=200

# Optional SMTP fallback (used only when OTP_DELIVERY_PROVIDER=smtp)
OTP_SMTP_HOST=smtp.gmail.com
OTP_SMTP_PORT=587
OTP_SMTP_SECURE=false
OTP_SMTP_USERNAME=<sender_email@example.com>
OTP_SMTP_APP_PASSWORD=<gmail_app_password_16_chars>
OTP_SMTP_FROM_EMAIL=<sender_email@example.com>
OTP_SMTP_TIMEOUT_MS=20000

# Request dedupe / concurrency
REQUEST_DEDUPE_WINDOW_SECONDS=30
REQUEST_CREATE_USE_DB_LOCK=true

# Abuse protection + rate limit
ABUSE_PROTECTION_ENABLED=true
ABUSE_PROTECTION_STORE=postgres
ABUSE_PROTECTION_MAX_ENTRIES=50000
ABUSE_PROTECTION_POSTGRES_RETRY_AFTER_SECONDS=30
ABUSE_PROTECTION_POSTGRES_CLEANUP_INTERVAL_SECONDS=300
ABUSE_PROTECTION_POSTGRES_RETENTION_HOURS=48
ABUSE_PROTECTION_POSTGRES_TRANSACTION_MAX_WAIT_MS=10000
ABUSE_PROTECTION_POSTGRES_TRANSACTION_TIMEOUT_MS=12000
ABUSE_PROTECTION_POSTGRES_TRANSIENT_RETRIES=2
ABUSE_PROTECTION_POSTGRES_TRANSIENT_RETRY_DELAY_MS=120
ABUSE_PROTECTION_POSTGRES_FAIL_CLOSED_IN_PRODUCTION=true

RATE_LIMIT_OTP_SEND_WINDOW_SECONDS=60
RATE_LIMIT_OTP_SEND_MAX_REQUESTS=5
RATE_LIMIT_OTP_SEND_BLOCK_SECONDS=300
RATE_LIMIT_OTP_VERIFY_WINDOW_SECONDS=60
RATE_LIMIT_OTP_VERIFY_MAX_REQUESTS=10
RATE_LIMIT_OTP_VERIFY_BLOCK_SECONDS=300
RATE_LIMIT_ADMIN_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_ADMIN_LOGIN_BLOCK_SECONDS=600
RATE_LIMIT_REQUEST_CREATE_WINDOW_SECONDS=60
RATE_LIMIT_REQUEST_CREATE_MAX_REQUESTS=30
RATE_LIMIT_REQUEST_CREATE_BLOCK_SECONDS=120
RATE_LIMIT_MESSENGER_LINK_WINDOW_SECONDS=60
RATE_LIMIT_MESSENGER_LINK_MAX_REQUESTS=30
RATE_LIMIT_MESSENGER_LINK_BLOCK_SECONDS=120

# Attachments
ATTACHMENT_UPLOAD_TICKET_SECRET=<generate_random_secret_32_plus_chars>
ATTACHMENT_UPLOAD_TICKET_TTL_SECONDS=900
ATTACHMENT_PUBLIC_UPLOAD_SESSION_TTL_SECONDS=1800
ATTACHMENT_DOWNLOAD_URL_TTL_SECONDS=900
ATTACHMENT_STORAGE_PROVIDER=b2
ATTACHMENT_STORAGE_BASE_URL=https://<railway-backend-domain>/storage/mock
ATTACHMENT_LOCAL_MOCK_MAX_UPLOAD_BYTES=104857600

# Required when ATTACHMENT_STORAGE_PROVIDER=webhook
ATTACHMENT_STORAGE_WEBHOOK_URL=
ATTACHMENT_STORAGE_WEBHOOK_API_KEY=
ATTACHMENT_STORAGE_WEBHOOK_SIGNING_SECRET=
ATTACHMENT_STORAGE_WEBHOOK_TIMEOUT_MS=5000
ATTACHMENT_STORAGE_WEBHOOK_MAX_RETRIES=2
ATTACHMENT_STORAGE_WEBHOOK_RETRY_DELAY_MS=200

# Backblaze B2
ATTACHMENT_B2_BUCKET_NAME=<b2_bucket_name>
ATTACHMENT_B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
ATTACHMENT_B2_REGION=us-west-004
ATTACHMENT_B2_ACCESS_KEY_ID=<b2_access_key_id>
ATTACHMENT_B2_SECRET_ACCESS_KEY=<b2_secret_access_key>
ATTACHMENT_B2_MAX_PRESIGN_TTL_SECONDS=3600

# Messenger
MESSENGER_MAGIC_LINK_SECRET=<generate_random_secret_32_plus_chars>
MESSENGER_MAGIC_LINK_TTL_HOURS=72
MESSENGER_MUTATION_REPLAY_WINDOW_SECONDS=5
MESSENGER_MAGIC_LINK_BASE_URL=https://<vercel-production-domain>/messenger/link

# Admin
ADMIN_USERNAME=<admin_username>
ADMIN_PASSWORD=<strong_admin_password>
ADMIN_SESSION_SECRET=<generate_random_secret_32_plus_chars>
ADMIN_SESSION_TTL_MINUTES=480
ADMIN_REMEMBER_SESSION_TTL_MINUTES=10080

# Retention / PDPA
RETENTION_ENABLED=false
RETENTION_RUN_ON_STARTUP=false
RETENTION_INTERVAL_HOURS=24
RETENTION_USE_DB_LOCK=true
RETENTION_DB_LOCK_KEY=48151623
RETENTION_OTP_SESSIONS_DAYS=7
RETENTION_EMPLOYEE_SESSIONS_DAYS=7
RETENTION_NOTIFICATIONS_DAYS=180
RETENTION_ACTIVITY_LOGS_DAYS=365
RETENTION_ADMIN_SESSIONS_DAYS=30
PDPA_ANONYMIZE_MIN_CLOSED_DAYS=30

