# Backend base URL used by Next.js server-side proxy route (recommended)
BACKEND_API_BASE_URL=http://localhost:3001

# Optional public fallback for local development / legacy direct calls
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Auth token storage mode: session (recommended) | memory
# session: persists per-tab using sessionStorage (recommended for admin refresh stability)
# memory: no browser persistence, lower XSS exposure
NEXT_PUBLIC_AUTH_TOKEN_STORAGE=session

# Optional extra connect-src entries for CSP (comma-separated)
# FRONTEND_CSP_CONNECT_SRC=https://api.example.com,https://cdn.example.com
# Optional extra asset/media/frame entries for CSP (comma-separated)
# FRONTEND_CSP_IMG_SRC=https://s3.us-west-004.backblazeb2.com
# FRONTEND_CSP_MEDIA_SRC=https://s3.us-west-004.backblazeb2.com
# FRONTEND_CSP_FRAME_SRC=https://s3.us-west-004.backblazeb2.com

# Optional smoke/release-gate tuning
# FRONTEND_SMOKE_BASE_URL=http://127.0.0.1:3000
# FRONTEND_SMOKE_HOST=127.0.0.1
# FRONTEND_SMOKE_PORT=3105
# SMOKE_ROUTE_TIMEOUT_MS=15000
# SMOKE_ROUTE_RETRIES=2
# SMOKE_ROUTE_RETRY_DELAY_MS=500
# SMOKE_SERVER_READY_TIMEOUT_MS=120000
# SMOKE_API_TIMEOUT_MS=7000
# SMOKE_REQUIRE_API=false

# Optional API contract timeout (ms)
# API_CONTRACT_TIMEOUT_MS=7000
