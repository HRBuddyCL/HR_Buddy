# ------------------------------------------------------------------------------
# HR-Buddy frontend deploy environment template (Vercel production)
# ------------------------------------------------------------------------------
# How to use:
# 1) Add these environment variables in Vercel project settings.
# 2) Replace placeholders before deploying.
# 3) Do not commit real secrets/tokens in repository.
# ------------------------------------------------------------------------------

NODE_ENV=production

# Backend URL used by Next.js server-side API proxy routes (required)
BACKEND_API_BASE_URL=https://<railway-backend-domain>

# Public API base URL used in browser-side code (recommended to match backend)
NEXT_PUBLIC_API_BASE_URL=https://<railway-backend-domain>

# Auth token storage mode: session (recommended) | memory
NEXT_PUBLIC_AUTH_TOKEN_STORAGE=session

# Extra CSP sources (comma-separated) for direct browser connections/assets.
# Include storage CDN domains used by preview/download/upload.
FRONTEND_CSP_CONNECT_SRC=https://s3.us-west-004.backblazeb2.com
FRONTEND_CSP_IMG_SRC=https://s3.us-west-004.backblazeb2.com
FRONTEND_CSP_MEDIA_SRC=https://s3.us-west-004.backblazeb2.com
FRONTEND_CSP_FRAME_SRC=https://s3.us-west-004.backblazeb2.com

# ------------------------------------------------------------------------------
# Optional CI/release-gate tuning (not required for runtime app)
# ------------------------------------------------------------------------------
# FRONTEND_RELEASE_GATE_REQUIRE_API=true
# FRONTEND_RELEASE_GATE_SKIP_SMOKE=false
# FRONTEND_RELEASE_GATE_SMOKE_PORT=3005
#
# FRONTEND_SMOKE_BASE_URL=https://<vercel-production-domain>
# FRONTEND_SMOKE_HOST=127.0.0.1
# FRONTEND_SMOKE_PORT=3105
# SMOKE_ROUTE_TIMEOUT_MS=15000
# SMOKE_ROUTE_RETRIES=2
# SMOKE_ROUTE_RETRY_DELAY_MS=500
# SMOKE_SERVER_READY_TIMEOUT_MS=120000
# SMOKE_API_TIMEOUT_MS=7000
# SMOKE_REQUIRE_API=true
#
# API_CONTRACT_TIMEOUT_MS=7000
# MOCK_API_HOST=127.0.0.1
# MOCK_API_PORT=3001
